  "keyFeatures": [
    "x86/x86_64 CPU emulation on iOS using threaded code interpreter",
    "Linux syscall translation to iOS equivalents",
    "Alpine Linux filesystem support with fake filesystem database",
    "Terminal emulator with full TTY/PTY support",
    "File provider extension for iOS Files app integration",
    "64-bit architecture port (work in progress)",
    "Custom instruction decoder and JIT-like gadget execution"
  ],
